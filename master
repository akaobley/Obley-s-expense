  ],
};

const TYPE_LABELS = { income: 'Income', expense: 'Expense', loan: 'Long-term Loan', shortLoan: 'Short-term Loan', investment: 'Investment', lending: 'Lending' };
const TYPE_TO_KEY = { income: 'income', expense: 'expenses', loan: 'loans', shortLoan: 'shortLoans', investment: 'investments', lending: 'lending' };

let activeModalType = null;

function openAddModal(type) {
  if (type === 'auto') type = 'income';
  activeModalType = type;
  editingEntry = null;
  document.getElementById('modal-title').textContent = 'Add ' + TYPE_LABELS[type];
  renderModalBody(type, null);
  document.getElementById('modal').classList.add('open');
}

function openEdit(type, id) {
  activeModalType = type;
  const key = TYPE_TO_KEY[type];
  const entry = DATA[key].find(x => x.id === id);
  editingEntry = entry;
  document.getElementById('modal-title').textContent = 'Edit ' + TYPE_LABELS[type];
  renderModalBody(type, entry);
  document.getElementById('modal').classList.add('open');
}

function renderModalBody(type, entry) {
  const fields = FIELDS[type] || [];
  let html = '<div class="form-grid">';
  fields.forEach(f => {
    const val = entry ? (entry[f.key] ?? '') : '';
    html += `<div class="form-group${fields.length === 1 ? ' full' : ''}">`;
    html += `<label>${f.label}</label>`;
    if (f.type === 'select') {
      html += `<select id="field-${f.key}">` + f.options.map(o => `<option value="${o}" ${val === o ? 'selected' : ''}>${o.charAt(0).toUpperCase() + o.slice(1)}</option>`).join('') + '</select>';
    } else {
      html += `<input type="${f.type}" id="field-${f.key}" value="${val}" placeholder="${f.placeholder || ''}" step="${f.type === 'number' ? 'any' : undefined}">`;
    }
    html += '</div>';
  });
  html += '</div>';

  // Add type switcher
  html += `<div style="margin-top:14px;display:flex;gap:8px;flex-wrap:wrap;"><span style="font-size:11px;color:var(--text-dim);margin-top:4px">Type:</span>` +
    Object.keys(TYPE_LABELS).map(t => `<button class="btn" style="${t === type ? 'border-color:var(--accent);color:var(--accent)' : ''};padding:4px 10px;font-size:11px" onclick="switchModalType('${t}')">${TYPE_LABELS[t]}</button>`).join('') + '</div>';

  document.getElementById('modal-body').innerHTML = html;
}

function switchModalType(type) {
  activeModalType = type;
  editingEntry = null;
  document.getElementById('modal-title').textContent = 'Add ' + TYPE_LABELS[type];
  renderModalBody(type, null);
}

function saveEntry() {
  const type = activeModalType;
  const fields = FIELDS[type] || [];
  const key = TYPE_TO_KEY[type];
  const obj = {};
  for (const f of fields) {
    const el = document.getElementById('field-' + f.key);
    if (!el) continue;
    obj[f.key] = f.type === 'number' ? (parseFloat(el.value) || 0) : el.value;
  }
  if (!obj.name && !obj.lentBy) { toast('Please fill in required fields', 'error'); return; }

  if (editingEntry) {
    const idx = DATA[key].findIndex(x => x.id === editingEntry.id);
    DATA[key][idx] = { ...editingEntry, ...obj };
    toast('Entry updated ✓');
  } else {
    obj.id = genId();
    DATA[key].push(obj);
    toast('Entry added ✓');
  }
  closeModal();
  saveData();
}

function closeModal() {
  document.getElementById('modal').classList.remove('open');
  editingEntry = null;
}

function deleteEntry(type, id) {
  if (!confirm('Delete this entry?')) return;
  const key = TYPE_TO_KEY[type];
  DATA[key] = DATA[key].filter(x => x.id !== id);
  toast('Deleted');
  saveData();
}

// ===== EXPORT / IMPORT =====
function exportData() {
  const blob = new Blob([JSON.stringify(DATA, null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a'); a.href = url;
  a.download = 'obleys_finance_' + new Date().toISOString().slice(0, 10) + '.json';
  a.click(); URL.revokeObjectURL(url);
  toast('Data exported ✓');
}

function importData(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const imported = JSON.parse(e.target.result);
      if (imported.income && imported.expenses && imported.loans) {
        DATA = imported;
        saveData();
        toast('Data imported successfully ✓');
      } else { toast('Invalid file format', 'error'); }
    } catch { toast('Failed to parse file', 'error'); }
  };
  reader.readAsText(file);
  event.target.value = '';
}

// Close modal on overlay click
document.getElementById('modal').addEventListener('click', e => { if (e.target === e.currentTarget) closeModal(); });

