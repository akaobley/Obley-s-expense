<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SimilarWeb Credit Calculator</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;500;600;700&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
:root {
  --navy: #002b6b;
  --cyan: #00bcd4;
  --cyan-light: #e0f7fa;
  --white: #ffffff;
  --bg: #f5f7fb;
  --bg2: #eef1f8;
  --card: #ffffff;
  --border: rgba(0,43,107,0.10);
  --border-strong: rgba(0,43,107,0.18);
  --text: #0d1b2e;
  --text2: #4a5f7a;
  --text3: #8a9ab0;
  --green: #0f6e56;
  --green-bg: #e1f5ee;
  --amber: #ba7517;
  --amber-bg: #faeeda;
  --red: #a32d2d;
  --red-bg: #fcebeb;
  --blue: #185fa5;
  --blue-bg: #e6f1fb;
  --radius: 10px;
  --radius-lg: 16px;
  --shadow: 0 2px 12px rgba(0,43,107,0.07);
  --shadow-lg: 0 4px 24px rgba(0,43,107,0.10);
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  font-size: 14px;
  line-height: 1.6;
}

/* HEADER */
.header {
  background: var(--navy);
  padding: 0 2rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 56px;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.header-logo {
  display: flex;
  align-items: center;
  gap: 10px;
}
.logo-mark {
  width: 28px;
  height: 28px;
  background: var(--cyan);
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.logo-mark svg { width: 16px; height: 16px; fill: var(--navy); }
.logo-text { font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 700; color: #fff; letter-spacing: -0.01em; }
.logo-text span { color: var(--cyan); }
.header-badge {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  color: rgba(255,255,255,0.45);
  background: rgba(255,255,255,0.07);
  padding: 3px 9px;
  border-radius: 20px;
  border: 1px solid rgba(255,255,255,0.1);
}

/* LAYOUT */
.page { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }

/* HERO STRIP */
.hero { margin-bottom: 1.75rem; }
.hero h1 {
  font-family: 'Syne', sans-serif;
  font-size: 26px;
  font-weight: 700;
  color: var(--navy);
  letter-spacing: -0.02em;
  margin-bottom: 4px;
}
.hero p { font-size: 13px; color: var(--text2); max-width: 520px; }

/* BUDGET BAR */
.budget-card {
  background: var(--navy);
  border-radius: var(--radius-lg);
  padding: 1.1rem 1.5rem;
  display: flex;
  align-items: center;
  gap: 1.5rem;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
}
.budget-card label {
  font-size: 11px;
  font-weight: 500;
  color: rgba(255,255,255,0.5);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  white-space: nowrap;
}
.budget-input-group {
  display: flex;
  align-items: center;
  gap: 8px;
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: var(--radius);
  padding: 6px 12px;
  flex: 1;
  min-width: 200px;
  max-width: 280px;
}
.budget-input-group span { font-family: 'DM Mono', monospace; font-size: 12px; color: var(--cyan); }
.budget-input-group input {
  background: none;
  border: none;
  outline: none;
  color: #fff;
  font-family: 'DM Mono', monospace;
  font-size: 15px;
  width: 100%;
  font-weight: 500;
}
.budget-input-group input::placeholder { color: rgba(255,255,255,0.25); }
.budget-info {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  flex-wrap: wrap;
  margin-left: auto;
}
.budget-stat { text-align: right; }
.budget-stat .bs-val { font-family: 'DM Mono', monospace; font-size: 16px; font-weight: 500; color: #fff; }
.budget-stat .bs-label { font-size: 10px; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.08em; }
.budget-meter { flex: 1; min-width: 160px; }
.budget-meter-label { display: flex; justify-content: space-between; font-size: 10px; color: rgba(255,255,255,0.4); margin-bottom: 5px; font-family: 'DM Mono', monospace; }
.budget-track { height: 6px; background: rgba(255,255,255,0.1); border-radius: 3px; overflow: hidden; }
.budget-fill { height: 100%; border-radius: 3px; transition: width 0.35s ease, background 0.35s; }

/* MAIN GRID */
.main-grid { display: grid; grid-template-columns: 1fr 360px; gap: 1.25rem; align-items: start; }
@media(max-width:900px){ .main-grid { grid-template-columns:1fr; } }

/* TABS */
.tab-bar {
  display: flex;
  gap: 0;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  overflow: hidden;
  border-bottom: none;
}
.tabx {
  padding: 11px 20px;
  font-size: 13px;
  font-family: 'DM Sans', sans-serif;
  cursor: pointer;
  background: transparent;
  border: none;
  color: var(--text2);
  border-bottom: 2px solid transparent;
  transition: all 0.15s;
  font-weight: 400;
}
.tabx:hover { color: var(--text); background: var(--bg2); }
.tabx.active {
  color: var(--navy);
  font-weight: 500;
  border-bottom: 2px solid var(--cyan);
  background: var(--card);
}
.tab-panel {
  background: var(--card);
  border: 1px solid var(--border);
  border-top: none;
  border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  padding: 1.5rem;
  display: none;
}
.tab-panel.active { display: block; }

/* FORM */
.form-section-title {
  font-size: 11px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text3);
  margin: 1.1rem 0 .65rem;
  display: flex;
  align-items: center;
  gap: 8px;
}
.form-section-title::after { content:''; flex:1; height:1px; background:var(--border); }
.form-section-title:first-child { margin-top: 0; }
.fg { display: grid; gap: 10px; margin-bottom: 10px; }
.fg-2 { grid-template-columns: 1fr 1fr; }
.fg-3 { grid-template-columns: 1fr 1fr 1fr; }
.field { display: flex; flex-direction: column; gap: 4px; }
.field label { font-size: 11px; font-weight: 500; color: var(--text2); }
.field select, .field input[type=number] {
  background: var(--bg);
  border: 1px solid var(--border-strong);
  border-radius: var(--radius);
  padding: 8px 10px;
  font-size: 13px;
  font-family: 'DM Sans', sans-serif;
  color: var(--text);
  outline: none;
  transition: border-color 0.15s;
  width: 100%;
}
.field select:focus, .field input[type=number]:focus { border-color: var(--cyan); }
.hint { font-size: 11px; color: var(--text3); line-height: 1.4; }

/* FORMULA BAR */
.formula-bar {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-left: 3px solid var(--navy);
  border-radius: 0 var(--radius) var(--radius) 0;
  padding: 9px 13px;
  font-size: 11.5px;
  font-family: 'DM Mono', monospace;
  color: var(--text2);
  margin-bottom: 1.1rem;
  line-height: 1.7;
}
.formula-bar b { color: var(--navy); font-weight: 500; }

/* PRESETS */
.presets { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 1rem; }
.preset-btn {
  font-size: 11px;
  padding: 4px 10px;
  border: 1px solid var(--border-strong);
  border-radius: 20px;
  background: transparent;
  cursor: pointer;
  color: var(--text2);
  font-family: 'DM Sans', sans-serif;
  transition: all 0.15s;
}
.preset-btn:hover { background: var(--navy); color: #fff; border-color: var(--navy); }

/* RESULT */
.result-block {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1.1rem 1.25rem;
  margin-top: 1.1rem;
}
.result-title { font-size: 11px; color: var(--text3); text-transform: uppercase; letter-spacing: 0.07em; font-weight: 500; margin-bottom: 3px; }
.result-total { font-family: 'Syne', sans-serif; font-size: 28px; font-weight: 700; color: var(--navy); letter-spacing: -0.02em; margin-bottom: 3px; }
.result-sub { font-size: 12px; color: var(--text2); margin-bottom: .75rem; }
.stats-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; margin-bottom: .75rem; }
.stat-box { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: .75rem; text-align: center; }
.stat-lbl { font-size: 10px; color: var(--text3); text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 3px; }
.stat-val { font-family: 'DM Mono', monospace; font-size: 17px; font-weight: 500; color: var(--navy); }
.stat-sub { font-size: 10px; color: var(--text3); }
.breakdown-table { width: 100%; border-collapse: collapse; font-size: 12px; font-family: 'DM Mono', monospace; }
.breakdown-table td { padding: 4px 6px; border-bottom: 1px solid var(--border); }
.breakdown-table td:last-child { text-align: right; font-weight: 500; color: var(--text); }
.breakdown-table td:first-child { color: var(--text2); }

/* BUDGET PROGRESS IN RESULT */
.bprog { margin-bottom: .75rem; }
.bprog-row { display: flex; justify-content: space-between; font-size: 11px; color: var(--text3); margin-bottom: 4px; font-family: 'DM Mono', monospace; }
.bprog-track { height: 7px; background: var(--bg2); border-radius: 4px; overflow: hidden; border: 1px solid var(--border); }
.bprog-fill { height: 100%; border-radius: 4px; transition: width 0.35s, background 0.35s; }

/* ALERTS */
.alert {
  display: flex;
  gap: 10px;
  padding: 9px 12px;
  border-radius: var(--radius);
  font-size: 12px;
  line-height: 1.5;
  margin-top: 6px;
  align-items: flex-start;
}
.alert-icon { font-size: 13px; flex-shrink: 0; margin-top: 1px; font-style: normal; }
.a-green { background: var(--green-bg); border: 1px solid rgba(15,110,86,0.15); color: var(--green); }
.a-amber { background: var(--amber-bg); border: 1px solid rgba(186,117,23,0.15); color: var(--amber); }
.a-red { background: var(--red-bg); border: 1px solid rgba(163,45,45,0.15); color: var(--red); }
.a-blue { background: var(--blue-bg); border: 1px solid rgba(24,95,165,0.15); color: var(--blue); }

/* RESTRICTIONS */
.restrictions {
  margin-top: 1rem;
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.restrictions-hdr {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 14px;
  background: var(--bg2);
  cursor: pointer;
  font-size: 12px;
  font-weight: 500;
  color: var(--text2);
  user-select: none;
  transition: background 0.15s;
}
.restrictions-hdr:hover { background: var(--bg); }
.restrictions-hdr .chevron { transition: transform 0.2s; font-style: normal; }
.restrictions-hdr.open .chevron { transform: rotate(45deg); }
.restrictions-body { display: none; padding: 4px 0; }
.restrictions-body.open { display: block; }
.r-item { display: flex; gap: 10px; padding: 9px 14px; border-bottom: 1px solid var(--border); font-size: 12px; line-height: 1.5; }
.r-item:last-child { border-bottom: none; }
.r-dot { width: 18px; height: 18px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 9px; font-weight: 700; flex-shrink: 0; margin-top: 1px; }
.r-red { background: var(--red-bg); color: var(--red); }
.r-amber { background: var(--amber-bg); color: var(--amber); }
.r-blue { background: var(--blue-bg); color: var(--blue); }
.r-green { background: var(--green-bg); color: var(--green); }
.r-name { font-weight: 500; color: var(--text); margin-bottom: 2px; }
.r-desc { color: var(--text2); }

/* SIDEBAR */
.sidebar { display: flex; flex-direction: column; gap: 1rem; }
.side-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.1rem 1.25rem; box-shadow: var(--shadow); }
.side-card-title { font-family: 'Syne', sans-serif; font-size: 13px; font-weight: 600; color: var(--navy); margin-bottom: .75rem; display: flex; align-items: center; gap: 7px; }
.side-card-title .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--cyan); }

/* COMPARE CHART */
.compare-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; margin-bottom: 1rem; }
.cmp-card { border: 1px solid var(--border); border-radius: var(--radius); padding: .85rem; text-align: center; background: var(--bg); position: relative; }
.cmp-card.winner { border: 2px solid var(--red); background: var(--red-bg); }
.cmp-tag { position: absolute; top: -10px; left: 50%; transform: translateX(-50%); background: var(--red); color: #fff; font-size: 9px; padding: 2px 8px; border-radius: 20px; white-space: nowrap; font-weight: 500; }
.cmp-name { font-size: 10px; color: var(--text3); text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 4px; }
.cmp-val { font-family: 'DM Mono', monospace; font-size: 16px; font-weight: 500; color: var(--navy); }
.cmp-pct { font-size: 10px; color: var(--text3); margin-top: 2px; }
.cmp-bar { height: 4px; border-radius: 2px; margin-top: 7px; transition: width 0.35s; }

/* MCP WARN */
.mcp-warn {
  background: linear-gradient(135deg, #fcebeb 0%, #faeeda 100%);
  border: 1px solid rgba(163,45,45,0.2);
  border-radius: var(--radius);
  padding: 10px 13px;
  font-size: 12px;
  color: var(--red);
  line-height: 1.5;
  margin-bottom: .85rem;
}
.mcp-warn b { font-weight: 500; }

/* FOOTER */
.footer {
  background: var(--navy);
  color: rgba(255,255,255,0.4);
  text-align: center;
  padding: 1.25rem;
  font-size: 11px;
  font-family: 'DM Mono', monospace;
}
.footer a { color: var(--cyan); text-decoration: none; }
</style>
</head>
<body>

<header class="header">
  <div class="header-logo">
    <div class="logo-mark">
      <svg viewBox="0 0 16 16"><path d="M2 12 L6 7 L9 10 L12 5 L14 7"/><polyline points="2,12 6,7 9,10 12,5 14,7" fill="none" stroke="#002b6b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div class="logo-text">SimilarWeb <span>Credits</span></div>
  </div>
  <div class="header-badge">v2.0 · Batch API · REST API · MCP</div>
</header>

<main class="page">

  <div class="hero">
    <h1>Data Credits Calculator</h1>
    <p>Estimate credit consumption across the Batch API, REST API, and MCP before you run. Set a monthly budget and get live alerts.</p>
  </div>

  <!-- BUDGET CARD -->
  <div class="budget-card">
    <div>
      <label>Monthly credit budget</label>
      <div class="budget-input-group" style="margin-top:6px">
        <span>#</span>
        <input type="number" id="global-budget" value="1000000" placeholder="e.g. 1000000" oninput="updateAll()">
      </div>
    </div>
    <div class="budget-meter" style="flex:1;min-width:200px">
      <div class="budget-meter-label">
        <span>Combined usage</span>
        <span id="budget-pct-label">0%</span>
      </div>
      <div class="budget-track">
        <div class="budget-fill" id="budget-fill-bar" style="width:0%;background:#1d9e75"></div>
      </div>
    </div>
    <div class="budget-info">
      <div class="budget-stat">
        <div class="bs-val" id="bstat-used">0</div>
        <div class="bs-label">est. used</div>
      </div>
      <div class="budget-stat">
        <div class="bs-val" id="bstat-remain">1,000,000</div>
        <div class="bs-label">remaining</div>
      </div>
    </div>
  </div>

  <div class="main-grid">

    <!-- LEFT: TABS -->
    <div>
      <div class="tab-bar">
        <button class="tabx active" onclick="switchTab('batch',this)">Batch API</button>
        <button class="tabx" onclick="switchTab('rest',this)">REST API</button>
        <button class="tabx" onclick="switchTab('mcp',this)">MCP</button>
        <button class="tabx" onclick="switchTab('compare',this)">Compare all</button>
      </div>

      <!-- BATCH -->
      <div class="tab-panel active" id="tab-batch">
        <div class="formula-bar"><b>Formula:</b> domains × metric_price × metrics × cadence × months × countries = total credits</div>
        <div class="presets">
          <span style="font-size:11px;color:var(--text3);align-self:center">Presets:</span>
          <button class="preset-btn" onclick="presetBatch(10,10,'1',1,1)">Small</button>
          <button class="preset-btn" onclick="presetBatch(50,15,'1',3,2)">Medium</button>
          <button class="preset-btn" onclick="presetBatch(100,20,'30',6,5)">Large / daily</button>
          <button class="preset-btn" onclick="presetBatch(500,25,'4',12,10)">Enterprise</button>
        </div>

        <div class="form-section-title">Dataset</div>
        <div class="fg fg-2">
          <div class="field">
            <label>Metric type</label>
            <select id="b-dataset" oninput="calcBatch()">
              <option value="1">Website traffic &amp; engagement (1 cr/cell)</option>
              <option value="1">Website referrals (1 cr/cell)</option>
              <option value="1">Audience / demographics (1 cr/cell)</option>
              <option value="1">App analysis (1 cr/cell)</option>
              <option value="1">Company firmographics (1 cr/cell)</option>
              <option value="1">Technographics (1 cr/cell)</option>
              <option value="1">Ecommerce brand/category (1 cr/cell)</option>
              <option value="0.1">Popular pages &amp; similar sites (1 cr/10)</option>
              <option value="0.01">Keywords datasets (1 cr/100)</option>
            </select>
          </div>
          <div class="field">
            <label>Number of domains</label>
            <input type="number" id="b-domains" min="1" value="10" oninput="calcBatch()">
            <span class="hint">Max ~10,000 domains per Batch request</span>
          </div>
        </div>

        <div class="form-section-title">Query scope</div>
        <div class="fg fg-3">
          <div class="field">
            <label>Number of metrics</label>
            <input type="number" id="b-metrics" min="1" value="10" oninput="calcBatch()">
          </div>
          <div class="field">
            <label>Cadence</label>
            <select id="b-cadence" oninput="calcBatch()">
              <option value="1">Monthly (×1)</option>
              <option value="4">Weekly (×4)</option>
              <option value="30">Daily (×30)</option>
            </select>
          </div>
          <div class="field">
            <label>Country filters</label>
            <input type="number" id="b-countries" min="1" value="1" oninput="calcBatch()">
          </div>
        </div>
        <div class="fg fg-2">
          <div class="field">
            <label>Months of historical data</label>
            <input type="number" id="b-months" min="1" max="61" value="3" oninput="calcBatch()">
            <span class="hint">Max 61 mo (traffic) · 27 mo (keywords) · 1 mo (firmographics)</span>
          </div>
        </div>

        <div id="batch-result"></div>
        <div id="batch-restrictions"></div>
      </div>

      <!-- REST -->
      <div class="tab-panel" id="tab-rest">
        <div class="formula-bar"><b>Formula:</b> domains × metrics × cadence × months × countries × calls/month = monthly total. No charge if no data returned.</div>
        <div class="presets">
          <span style="font-size:11px;color:var(--text3);align-self:center">Presets:</span>
          <button class="preset-btn" onclick="presetRest(10,5,'1',1,1,1)">Lightweight</button>
          <button class="preset-btn" onclick="presetRest(50,10,'1',3,2,10)">Standard</button>
          <button class="preset-btn" onclick="presetRest(200,20,'30',6,5,30)">Heavy pipeline</button>
        </div>

        <div class="form-section-title">Query config</div>
        <div class="fg fg-2">
          <div class="field"><label>Domains / entities</label><input type="number" id="r-domains" min="1" value="10" oninput="calcRest()"></div>
          <div class="field"><label>Metrics / endpoints</label><input type="number" id="r-metrics" min="1" value="5" oninput="calcRest()"></div>
        </div>
        <div class="fg fg-3">
          <div class="field">
            <label>Cadence</label>
            <select id="r-cadence" oninput="calcRest()">
              <option value="1">Monthly (×1)</option>
              <option value="4">Weekly (×4)</option>
              <option value="30">Daily (×30)</option>
            </select>
          </div>
          <div class="field"><label>Months of data</label><input type="number" id="r-months" min="1" max="61" value="3" oninput="calcRest()"></div>
          <div class="field"><label>Country filters</label><input type="number" id="r-countries" min="1" value="1" oninput="calcRest()"></div>
        </div>
        <div class="fg fg-2">
          <div class="field">
            <label>API calls per month</label>
            <input type="number" id="r-calls" min="1" value="1" oninput="calcRest()">
            <span class="hint">How many times you run this query each month</span>
          </div>
        </div>

        <div id="rest-result"></div>
        <div id="rest-restrictions"></div>
      </div>

      <!-- MCP -->
      <div class="tab-panel" id="tab-mcp">
