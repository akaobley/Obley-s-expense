  chartInstances['debt-user-chart'] = new Chart(document.getElementById('debt-user-chart'), {
    type: 'doughnut',
    data: {
      labels: Object.keys(userDebts),
      datasets: [{ data: Object.values(userDebts), backgroundColor: ['rgba(248,113,113,0.8)', 'rgba(108,142,255,0.8)', 'rgba(52,211,153,0.8)'], borderWidth: 0, hoverOffset: 6 }]
    },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { color: '#8a94aa', padding: 10, font: { size: 12 } } }, tooltip: { callbacks: { label: ctx => ` ${ctx.label}: ${fmtL(ctx.raw)}` } } }, cutout: '60%' }
  });

  // Preeth individual loan payoff
  const preethLabels = [], hdfc = [], icici = [], short = [];
  for (let i = 0; i <= 60; i++) {
    const d = new Date(now.getFullYear(), now.getMonth() + i, 1);
    preethLabels.push(d.toLocaleDateString('en-IN', { month: 'short', year: '2-digit' }));
    const hdfcLoan = DATA.loans.find(l => l.id === 'l1');
    const iciciLoan = DATA.loans.find(l => l.id === 'l2');
    hdfc.push(hdfcLoan ? Math.max(0, hdfcLoan.outstanding - hdfcLoan.emi * i * 0.65) : 0);
    icici.push(iciciLoan ? Math.max(0, iciciLoan.outstanding - iciciLoan.emi * i * 0.65) : 0);
    short.push(Math.max(0, DATA.shortLoans.filter(l => l.user === 'preeth').reduce((s, l) => s + Math.max(0, l.outstanding - l.emi * i), 0)));
  }

  chartInstances['preeth-debt-chart'] = new Chart(document.getElementById('preeth-debt-chart'), {
    type: 'line',
    data: {
      labels: preethLabels,
      datasets: [
        { label: 'HDFC PL', data: hdfc, borderColor: 'rgba(248,113,113,0.9)', tension: 0.4, fill: false, pointRadius: 0 },
        { label: 'ICICI PL', data: icici, borderColor: 'rgba(251,191,36,0.9)', tension: 0.4, fill: false, pointRadius: 0 },
        { label: 'Short-term', data: short, borderColor: 'rgba(167,139,250,0.9)', tension: 0.4, fill: false, pointRadius: 0 },
      ]
    },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { labels: { color: '#8a94aa', font: { size: 11 } } } }, scales: { x: { ticks: { color: '#8a94aa', maxTicksLimit: 12, font: { size: 10 } }, grid: { color: '#1e2330' } }, y: { ticks: { color: '#8a94aa', callback: v => fmtL(v), font: { size: 10 } }, grid: { color: '#1e2330' } } } }
  });

  // EMI vs Income bar
  const totalIncome = DATA.income.reduce((s, x) => s + x.amount, 0);
  const totalEMI = DATA.loans.filter(l => l.status !== 'Completed').reduce((s, x) => s + x.emi, 0) + DATA.shortLoans.reduce((s, x) => s + x.emi, 0);
  const totalExp = DATA.expenses.reduce((s, x) => s + x.amount, 0);
  const totalInvest = DATA.investments.reduce((s, x) => s + x.monthly, 0);

  chartInstances['emi-vs-income-chart'] = new Chart(document.getElementById('emi-vs-income-chart'), {
    type: 'bar',
    data: {
      labels: ['Rental Income', 'Loan EMIs', 'Recurring Exp.', 'Investments', 'Net'],
      datasets: [{
        data: [totalIncome, totalEMI, totalExp, totalInvest, totalIncome - totalEMI - totalExp - totalInvest],
        backgroundColor: ['rgba(52,211,153,0.7)', 'rgba(248,113,113,0.7)', 'rgba(251,191,36,0.7)', 'rgba(167,139,250,0.7)', (totalIncome - totalEMI - totalExp - totalInvest) >= 0 ? 'rgba(52,211,153,0.7)' : 'rgba(248,113,113,0.7)'],
        borderRadius: 6
      }]
    },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { ticks: { color: '#8a94aa', font: { size: 11 } }, grid: { color: '#1e2330' } }, y: { ticks: { color: '#8a94aa', callback: v => fmtL(v), font: { size: 10 } }, grid: { color: '#1e2330' } } } }
  });

  // Milestone table
  const allLoans = [...DATA.loans.filter(l => l.status !== 'Completed'), ...DATA.shortLoans.map(l => ({ ...l, endDate: null, emi: l.emi, outstanding: l.outstanding, interestTotal: 0, name: l.name + ' (App)' }))];
  document.getElementById('milestone-tbody').innerHTML = allLoans.map(l => {
    const ml = monthsLeft(l.endDate);
    const total = l.outstanding + (l.interestTotal || 0);
    const pct = total > 0 ? Math.round(((l.principal || l.outstanding) / (l.principal + (l.interestTotal || 0))) * 100) : 0;
    return `<tr>
      <td>${l.name}</td>
      <td><span class="pill ongoing">${l.user}</span></td>
      <td style="color:var(--red)">${fmtL(l.outstanding)}</td>
      <td style="color:var(--yellow)">${fmt(l.emi)}</td>
      <td>${l.endDate || (l.months ? l.months + ' mo left' : '—')}</td>
      <td>
        <div class="progress-wrap" style="min-width:100px">
          <div class="progress-bar"><div class="progress-fill" style="width:${pct}%;background:var(--accent)"></div></div>
          <div style="font-size:10px;color:var(--text-muted);margin-top:3px">${pct}% paid</div>
        </div>
      </td>
    </tr>`;
  }).join('');
}

function destroyChart(id) {
  if (chartInstances[id]) { chartInstances[id].destroy(); delete chartInstances[id]; }
}

