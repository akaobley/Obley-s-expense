<script>
var batchTotal=0, restTotal=0, mcpLow=0, mcpHigh=0;
var cmpChart=null;

function fmt(n){ return Math.round(n).toLocaleString(); }
function pct(v,max){ return max>0 ? Math.min(100,Math.round(v/max*100)) : 0; }
function getBudget(){ return parseInt(document.getElementById('global-budget').value)||0; }

function switchTab(t,el){
  document.querySelectorAll('.tabx').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(s=>s.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('tab-'+t).classList.add('active');
  if(t==='compare') renderCompare();
}

function updateBudgetBar(){
  var budget=getBudget();
  var combined=batchTotal+restTotal+Math.round((mcpLow+mcpHigh)/2||0);
  var p=pct(combined,budget);
  var fill=p>=100?'#e24b4a':p>=80?'#ba7517':'#1d9e75';
  var bar=document.getElementById('budget-fill-bar');
  bar.style.width=p+'%';
  bar.style.background=fill;
  document.getElementById('budget-pct-label').textContent=p+'%';
  document.getElementById('bstat-used').textContent=fmt(combined);
  document.getElementById('bstat-remain').textContent=fmt(Math.max(0,budget-combined));
}

function budgetProgressHtml(val, label){
  var budget=getBudget();
  if(!budget) return '';
  var p=pct(val,budget);
  var fill=p>=100?'#e24b4a':p>=80?'#ba7517':'#1d9e75';
  var alert='';
  if(p>=100) alert='<div class="alert a-red"><i class="alert-icon">✕</i><div><b>Over budget!</b> Exceeds monthly budget by '+fmt(val-budget)+' credits. Reduce domains, metrics, or historical range.</div></div>';
  else if(p>=80) alert='<div class="alert a-amber"><i class="alert-icon">!</i><div><b>Near limit ('+p+'%).</b> This query uses most of your monthly budget. Leave headroom for other queries.</div></div>';
  else alert='<div class="alert a-green"><i class="alert-icon">✓</i><div>Within budget — '+p+'% used, '+fmt(budget-val)+' credits remaining.</div></div>';
  return '<div class="bprog"><div class="bprog-row"><span>'+fmt(val)+' of '+fmt(budget)+'</span><span>'+p+'%</span></div><div class="bprog-track"><div class="bprog-fill" style="width:'+p+'%;background:'+fill+'"></div></div></div>'+alert;
}

function buildRestrictions(items){
  var id='r'+Math.random().toString(36).slice(2,7);
  var html='<div class="restrictions"><div class="restrictions-hdr" onclick="toggleR(this)"><span>Restrictions &amp; things to know <span style="background:var(--bg2);border:1px solid var(--border);border-radius:20px;padding:1px 7px;font-family:\'DM Mono\',monospace;font-size:10px;margin-left:4px">'+items.length+'</span></span><i class="chevron">+</i></div><div class="restrictions-body">';
  items.forEach(function(it){
    var cls=it.type==='red'?'r-red':it.type==='amber'?'r-amber':it.type==='blue'?'r-blue':'r-green';
    var sym=it.type==='red'?'✕':it.type==='amber'?'!':it.type==='blue'?'i':'✓';
    html+='<div class="r-item"><div class="r-dot '+cls+'">'+sym+'</div><div><div class="r-name">'+it.name+'</div><div class="r-desc">'+it.desc+'</div></div></div>';
  });
  html+='</div></div>';
  return html;
}

function toggleR(el){
  el.classList.toggle('open');
  el.nextElementSibling.classList.toggle('open');
  el.querySelector('.chevron').textContent=el.classList.contains('open')?'−':'+';
}

function calcBatch(){
  var price=parseFloat(document.getElementById('b-dataset').value)||1;
  var domains=parseInt(document.getElementById('b-domains').value)||1;
  var metrics=parseInt(document.getElementById('b-metrics').value)||1;
  var cadence=parseInt(document.getElementById('b-cadence').value)||1;
  var months=parseInt(document.getElementById('b-months').value)||1;
  var countries=parseInt(document.getElementById('b-countries').value)||1;
  var total=domains*price*metrics*cadence*months*countries;
  batchTotal=total;
  updateBudgetBar();

  var html='<div class="result-block">'
    +'<div class="result-title">Estimated credits</div>'
    +'<div class="result-total">'+fmt(total)+'</div>'
    +'<div class="result-sub">for this query configuration</div>'
    +budgetProgressHtml(total,'batch')
    +'<div class="stats-row">'
    +'<div class="stat-box"><div class="stat-lbl">Domains</div><div class="stat-val">'+fmt(domains)+'</div></div>'
    +'<div class="stat-box"><div class="stat-lbl">Metrics</div><div class="stat-val">'+fmt(metrics)+'</div></div>'
    +'<div class="stat-box"><div class="stat-lbl">Countries</div><div class="stat-val">'+fmt(countries)+'</div></div>'
    +'</div>'
    +'<table class="breakdown-table">'
    +'<tr><td>Domains</td><td>'+fmt(domains)+'</td></tr>'
    +'<tr><td>× metric price</td><td>'+price+'</td></tr>'
    +'<tr><td>× '+fmt(metrics)+' metrics</td><td>'+fmt(domains*price*metrics)+'</td></tr>'
    +'<tr><td>× cadence ×'+cadence+'</td><td>'+fmt(domains*price*metrics*cadence)+'</td></tr>'
    +'<tr><td>× '+months+' months</td><td>'+fmt(domains*price*metrics*cadence*months)+'</td></tr>'
    +'<tr><td>× '+countries+' countr'+(countries>1?'ies':'y')+'</td><td>'+fmt(total)+'</td></tr>'
    +'</table>'
    +'<div style="font-size:11px;color:var(--text3);margin-top:.6rem">Tip: use <code>request-validate</code> endpoint for a pre-run estimate before executing large jobs.</div>'
    +'</div>';
  document.getElementById('batch-result').innerHTML=html;

  var r=[];
  if(domains>10000) r.push({type:'red',name:'Domain limit exceeded',desc:'Batch API supports a maximum of ~10,000 domains per request. Split into multiple calls.'});
  if(months>61) r.push({type:'red',name:'Historical data cap',desc:'Most traffic metrics support up to 61 months. Keywords max 27 months. Firmographics: 1 month only.'});
  if(price===0.01&&months>27) r.push({type:'red',name:'Keywords history limit',desc:'Keywords datasets only support up to 27 months of historical data.'});
  if(cadence===30) r.push({type:'amber',name:'Daily cadence — high credit burn',desc:'Daily granularity multiplies credits by 30×. Use monthly or weekly for trend analysis unless daily precision is required.'});
  if(countries>5) r.push({type:'amber',name:'High country filter count',desc:'Each country filter multiplies credits linearly. Consider using the global filter where granularity allows.'});
  if(months>37&&price===1&&document.getElementById('b-dataset').selectedIndex>=1) r.push({type:'amber',name:'Historical limit varies by dataset',desc:'Some datasets (referrals, demographics) cap at 37 months, not 61. Excess months return no data — no charge, but wasted configuration.'});
  r.push({type:'blue',name:'Credits expire monthly',desc:'Unused credits do not roll over. Plan queries to stay within your monthly allowance.'});
  r.push({type:'blue',name:'Use request-validate before large jobs',desc:'Call the request-validate endpoint to get a pre-run credit estimate without consuming credits.'});
  r.push({type:'green',name:'No charge for empty results',desc:'API calls that return no data for a domain/metric are not billed.'});
  document.getElementById('batch-restrictions').innerHTML=buildRestrictions(r);
}

function calcRest(){
  var domains=parseInt(document.getElementById('r-domains').value)||1;
  var metrics=parseInt(document.getElementById('r-metrics').value)||1;
  var cadence=parseInt(document.getElementById('r-cadence').value)||1;
  var months=parseInt(document.getElementById('r-months').value)||1;
  var countries=parseInt(document.getElementById('r-countries').value)||1;
  var calls=parseInt(document.getElementById('r-calls').value)||1;
  var perQuery=domains*metrics*cadence*months*countries;
  var total=perQuery*calls;
  restTotal=total;
  updateBudgetBar();

  var html='<div class="result-block">'
    +'<div class="result-title">Estimated monthly credits</div>'
    +'<div class="result-total">'+fmt(total)+'</div>'
    +'<div class="result-sub">'+fmt(calls)+' call'+(calls>1?'s':'')+' × '+fmt(perQuery)+' credits/run</div>'
    +budgetProgressHtml(total,'rest')
    +'<div class="stats-row">'
    +'<div class="stat-box"><div class="stat-lbl">Per query run</div><div class="stat-val">'+fmt(perQuery)+'</div></div>'
    +'<div class="stat-box"><div class="stat-lbl">Calls/month</div><div class="stat-val">'+fmt(calls)+'</div></div>'
    +'<div class="stat-box"><div class="stat-lbl">Monthly total</div><div class="stat-val">'+fmt(total)+'</div></div>'
    +'</div>'
    +'<table class="breakdown-table">'
    +'<tr><td>Domains</td><td>'+fmt(domains)+'</td></tr>'
    +'<tr><td>× '+fmt(metrics)+' metrics</td><td>'+fmt(domains*metrics)+'</td></tr>'
    +'<tr><td>× cadence ×'+cadence+'</td><td>'+fmt(domains*metrics*cadence)+'</td></tr>'
    +'<tr><td>× '+months+' months</td><td>'+fmt(domains*metrics*cadence*months)+'</td></tr>'
    +'<tr><td>× '+countries+' countr'+(countries>1?'ies':'y')+'</td><td>'+fmt(perQuery)+'</td></tr>'
    +'<tr><td>× '+fmt(calls)+' API calls/month</td><td>'+fmt(total)+'</td></tr>'
    +'</table>'
    +'</div>';
  document.getElementById('rest-result').innerHTML=html;

  var r=[];
  if(cadence===30) r.push({type:'amber',name:'Daily cadence — high credit burn',desc:'Daily granularity multiplies credits by 30×. Only use if daily resolution is essential.'});
  if(months>61) r.push({type:'red',name:'Historical data cap',desc:'Most REST endpoints support up to 61 months. Check endpoint-specific limits in the API documentation.'});
  if(countries>10) r.push({type:'amber',name:'Many country filters',desc:'Each country filter multiplies credit usage linearly. Batch country calls carefully.'});
  r.push({type:'blue',name:'Credits expire monthly',desc:'Unused credits do not roll over to the following month.'});
  r.push({type:'blue',name:'Rate limits apply',desc:'REST API has per-endpoint rate limits. Implement exponential backoff to handle 429 errors gracefully.'});
  r.push({type:'blue',name:'Pagination counts',desc:'Paginated results consume credits for each page. Only paginate as far as you need.'});
  r.push({type:'green',name:'No charge for empty results',desc:'Calls that return no data are not billed — this protects against querying domains with no Similarweb coverage.'});
  document.getElementById('rest-restrictions').innerHTML=buildRestrictions(r);
}

function calcMcp(){
  var type=document.getElementById('m-type').value;
  var users=parseInt(document.getElementById('m-users').value)||1;
  document.getElementById('mcp-custom-fields').style.display=type==='custom'?'block':'none';
  var low,high;
  if(type==='avg'){low=5000;high=10000;}
  else if(type==='power'){low=50000;high=500000;}
  else{
    var p=parseInt(document.getElementById('m-prompts').value)||10;
    var c=parseInt(document.getElementById('m-cpp').value)||3;
    var pts=parseInt(document.getElementById('m-points').value)||100;
    var d=parseInt(document.getElementById('m-days').value)||22;
    var pd=p*c*pts*d;
    low=Math.round(pd*0.7); high=Math.round(pd*2);
  }
  var tl=low*users, th=high*users, mid=Math.round((tl+th)/2);
  mcpLow=tl; mcpHigh=th;
  updateBudgetBar();

  var html='<div class="result-block">'
    +'<div class="result-title">Estimated monthly credit range</div>'
    +'<div class="result-total">'+fmt(tl)+' – '+fmt(th)+'</div>'
    +'<div class="result-sub">across '+fmt(users)+' user'+(users>1?'s':'')+' · midpoint: '+fmt(mid)+'</div>'
    +budgetProgressHtml(mid,'mcp')
    +'<div class="stats-row">'
    +'<div class="stat-box"><div class="stat-lbl">Low estimate</div><div class="stat-val">'+fmt(tl)+'</div><div class="stat-sub">per month</div></div>'
    +'<div class="stat-box"><div class="stat-lbl">Midpoint</div><div class="stat-val">'+fmt(mid)+'</div><div class="stat-sub">per month</div></div>'
    +'<div class="stat-box"><div class="stat-lbl">High estimate</div><div class="stat-val">'+fmt(th)+'</div><div class="stat-sub">per month</div></div>'
    +'</div>'
    +'<div style="font-size:11px;color:var(--text3);margin-top:.5rem">Directional only. Check DaaS tracking dashboard MCP page for actuals from comparable accounts.</div>'
    +'</div>';
  document.getElementById('mcp-result').innerHTML=html;

  var r=[];
  r.push({type:'red',name:'Unpredictable credit burns',desc:'A single MCP prompt can trigger 2–6+ API calls. One prompt querying Meta used 568,000 credits. Monitor Credit Management dashboard at all times.'});
  r.push({type:'red',name:'No real-time credit output (yet)',desc:'Real-time per-query credit reporting is coming. Until then there is no live view of usage per MCP prompt as it runs.'});
  r.push({type:'amber',name:'Multiple endpoint calls per prompt',desc:'Each AI model approaches prompts differently and may call the same endpoint multiple times or explore related endpoints unpredictably.'});
  r.push({type:'amber',name:'Credit mapping not yet validated',desc:'MCP credit-to-query estimates are directional only — validation with Product is ongoing. Treat all estimates as approximate.'});
  r.push({type:'amber',name:'Shared credit pool',desc:'MCP users share the same credit pool as REST and Batch API. Heavy MCP usage can deplete credits available for other automated workflows.'});
  r.push({type:'blue',name:'Credits expire monthly',desc:'Unused credits do not roll over. Check the DaaS tracking dashboard MCP page for actual usage from similar accounts.'});
  r.push({type:'green',name:'No charge for empty results',desc:'If an MCP-triggered API call returns no data, no credits are charged — same rule as direct API access.'});
  document.getElementById('mcp-restrictions').innerHTML=buildRestrictions(r);
}

function renderCompare(){
  var budget=getBudget();
  var mid=Math.round((mcpLow+mcpHigh)/2);
  var vals=[batchTotal,restTotal,mid];
  var names=['Batch API','REST API','MCP (mid)'];
  var colors=['#378add','#1d9e75','#ba7517'];
  var maxV=Math.max.apply(null,vals)||1;
  var total=batchTotal+restTotal+mid;
  var highestIdx=vals.indexOf(Math.max.apply(null,vals));

  var grid='';
  vals.forEach(function(v,i){
    var p=pct(v,budget);
    grid+='<div class="cmp-card'+(i===highestIdx?' winner':'')+'">'+( i===highestIdx?'<span class="cmp-tag">highest</span>':'' )
      +'<div class="cmp-name">'+names[i]+'</div>'
      +'<div class="cmp-val">'+fmt(v)+'</div>'
      +(budget?'<div class="cmp-pct">'+p+'% of budget</div>':'')
      +'<div class="cmp-bar" style="background:'+colors[i]+';width:'+Math.round(v/maxV*100)+'%"></div>'
      +'</div>';
  });
  document.getElementById('compare-cards').innerHTML=grid;

  var ctx=document.getElementById('compare-chart').getContext('2d');
  if(cmpChart)cmpChart.destroy();
  var datasets=[{
    label:'Credits',
    data:vals,
    backgroundColor:colors,
    borderWidth:0,
    borderRadius:6
  }];
  if(budget){
    datasets.push({
      label:'Budget',
      data:[budget,budget,budget],
      type:'line',
      borderColor:'#e24b4a',
      borderWidth:1.5,
      borderDash:[5,4],
      pointRadius:0,
      fill:false
    });
  }
  cmpChart=new Chart(ctx,{
    type:'bar',
    data:{labels:names,datasets:datasets},
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false}},
      scales:{
        y:{beginAtZero:true,ticks:{callback:function(v){return v>=1000000?(v/1000000).toFixed(1)+'M':v>=1000?(v/1000).toFixed(0)+'K':v},font:{size:11},color:'#8a9ab0'},grid:{color:'rgba(0,43,107,0.05)'}},
        x:{ticks:{font:{size:12},color:'#4a5f7a'},grid:{display:false}}
      }
    }
  });

  var totalBudgetPct=pct(total,budget);
  var analysisCls=totalBudgetPct>=100?'a-red':totalBudgetPct>=80?'a-amber':'a-green';
  var sym=totalBudgetPct>=100?'✕':totalBudgetPct>=80?'!':'✓';
  var aText=totalBudgetPct>=100
    ?'<b>Combined usage exceeds budget</b> by '+fmt(total-budget)+' credits.'
    :'Combined usage is '+totalBudgetPct+'% of your monthly budget.';

  document.getElementById('compare-analysis').innerHTML=
    '<div style="background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:10px 14px;font-size:12px;color:var(--text2);margin-bottom:.75rem">'
    +'<b style="color:var(--text)">Combined monthly estimate:</b> '+fmt(total)+' credits'+(budget?' of '+fmt(budget)+' budget ('+totalBudgetPct+'%)':'')
    +'<br>Batch: '+Math.round(batchTotal/(total||1)*100)+'% · REST: '+Math.round(restTotal/(total||1)*100)+'% · MCP: '+Math.round(mid/(total||1)*100)+'%'
    +'</div>'
    +(budget?'<div class="alert '+analysisCls+'"><i class="alert-icon">'+sym+'</i><div>'+aText+'</div></div>':'');
}

function presetBatch(d,m,cad,mo,co){
  document.getElementById('b-domains').value=d;
  document.getElementById('b-metrics').value=m;
  document.getElementById('b-cadence').value=cad;
  document.getElementById('b-months').value=mo;
  document.getElementById('b-countries').value=co;
  calcBatch();
}
function presetRest(d,m,cad,mo,co,calls){
  document.getElementById('r-domains').value=d;
  document.getElementById('r-metrics').value=m;
  document.getElementById('r-cadence').value=cad;
  document.getElementById('r-months').value=mo;
  document.getElementById('r-countries').value=co;
  document.getElementById('r-calls').value=calls;
  calcRest();
}
function updateAll(){ calcBatch(); calcRest(); calcMcp(); }

calcBatch(); calcRest(); calcMcp();
</script>
</body>
</html>
