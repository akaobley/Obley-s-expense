  const preethLoans = DATA.loans.filter(l => l.user === 'preeth' && l.status !== 'Completed');
  const preethShort = DATA.shortLoans.filter(l => l.user === 'preeth');

  // Generate 36 months timeline
  for (let i = 0; i <= 36; i++) {
    const d = new Date(now.getFullYear(), now.getMonth() + i, 1);
    labels.push(d.toLocaleDateString('en-IN', { month: 'short', year: '2-digit' }));

    let pDebt = preethLoans.reduce((s, l) => {
      const ml = monthsLeft(l.endDate);
      return s + (ml === null || i <= (ml || 0) ? Math.max(0, l.outstanding - l.emi * i * 0.6) : 0);
    }, 0) + preethShort.reduce((s, l) => s + Math.max(0, l.outstanding - l.emi * i), 0);
